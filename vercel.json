{
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "functions": {
    "api/socket.js": {
      "memory": 256,
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/socket.io/(.*)",
      "destination": "/api/socket"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
